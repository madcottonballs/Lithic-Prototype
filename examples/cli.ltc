import "stringlib.ltc" as "strings";
import "strarraylib.ltc" as "strarray";

define main() {
    printf("Testing what an array of strings looks like:");
    let ptr[5] test;
    strarray.load(input(), 0, &test);

    iterate (i, length(test)) {
        printf(concat("test[", i -> string, "] = ", strings.read(test[i])));
        coredump();
    }
    return(0);
}