define #main
    make_var i32 -> %return_value
    call #ltc_main -> %return_value
    exit %return_value
end #main

define #ltc_main
    make_var string -> %test
    make_var char -> %chartest

    print ">>>"
    input -> %test

    print "you said: "
    printf %test

    ret i32 $0
end #ltc_main

define #ltcadd i32 i32
    make_var i32 -> %test
    add %arg0 %arg1 -> %test
    ret i32 %test
end #ltcadd