define #main
    make_var i32 -> %return_value
    call #ltc_main -> i32 %return_value
    exit %return_value
end #main

define #ltc_main
    make_var boolean -> %testbool
    mov boolean |true -> %testbool
    print %testbool
    ret i32 $0
end #ltc_main

define #ltcadd i32 i32
    make_var i32 -> %test
    add %arg0 %arg1 -> %test
    ret i32 %test
end #ltcadd