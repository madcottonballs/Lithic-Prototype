define #main
    make_var i32 -> %return_value
    call #ltc_main -> %return_value
    exit %return_value
end #main

define #ltc_main
    make_array i32 $3 -> %arrtest
    set_at $7 -> %arrtest i32 $0
    set_at $11 -> %arrtest i32 $1

    make_var tuple<i32,string> -> %pair
    

    ret i32 $0
end #ltc_main