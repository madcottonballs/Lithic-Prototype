define #main
    make_var i32 -> %return_value
    call #ltc_main -> %return_value
    exit %return_value
end #main

define #ltc_main
    make_var ptr -> %exam
    malloc 100 -> %exam

    make_var u8 -> %test

    set_at 50 -> %exam u8 0
    get_at %exam u8 0 -> %test
    printf %test
    free %exam

    ret i32 $0
end #ltc_main
