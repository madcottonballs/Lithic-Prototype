define int_casts(i32 x) {
    if (x -> string == "6") {
        printf("Integer -> String cast successful.");
    } else {
        printf("Integer -> String cast failed.");
    }
    if (x -> boolean == true) {
        printf("Integer -> Boolean cast successful.");
    } else {
        printf("Integer -> Boolean cast failed.");
    }
    if ((x -> string -> char == '6')) {
        printf("Integer -> char cast successful.");
    } else {
        printf("Integer -> char cast failed.");
    }
    return(0);
}
define main() {
    int_casts(6);
    return(0);
}