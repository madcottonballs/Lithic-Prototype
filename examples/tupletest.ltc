define scopetest() {
    let tuple x = makeTuple(i32, i32, i32);

    iterate(i, 3) {printf(x[i]);}
    let tuple y = makeTuple(i32, i32, i32);
    let tuple b = makeTuple(i32, u8, i32);
    let tuple z = concat(x, y, b);
    printf(z);
    printf(length(z));
    return(0);
}
define main() {
    scopetest();
    coredump(); 
    
    return(0);
}