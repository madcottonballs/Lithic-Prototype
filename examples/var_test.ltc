define test() {
    let ptr h = malloc(10);
    return(h);    
}
define main() { 
    printf("expected output: 6, Hello, world!, True, A, 5, <ptr as num>, <ptr as num>");

    let i32 x = 6;
    printf(x);

    let string str = "Hello, world!";
    printf(str);

    let boolean b = true;
    printf(b);

    let char c = 'A';
    printf(c);

    let ptr p = mallocType(u8, 5);
    tag(p, u8);
    printf(p);
    p[1] = 54;
    printf(p[0]);
    p[2] = 100;

    let ptr g = test();
    printf(g);
    return(0);
}