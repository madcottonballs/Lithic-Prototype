define test() {
    let ptr x = malloc(10);
    return(x);    
}
define main() { 
    let i32 x = 6;
    printf(x);
    let string str = "Hello, world!";
    printf(str);
    let boolean b = true;
    printf(b);
    let char c = 'A';
    printf(c);
    let ptr p = malloc(5);
    printf(p);
    let ptr g = test();
    printf(g);
    coredump();
    return(0);
}