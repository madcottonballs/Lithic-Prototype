define main() {
    let boolean continue = true;
    printf("Welcome to a program that tells you the ascii index of the text you enter.\nEnter \'cls\' to leave.");
    while (continue) {
        printf(">>>");
        let string user_input = input();
        if (user_input == "cls") {
            continue = false;
        } else {
            iterate (i, sLength(user_input)) {
                let char selected_char = user_input[i] -> char;
                /*let u8 */
                printf(selected_char -> u8);
            }
        }
    }
    return(0);
}