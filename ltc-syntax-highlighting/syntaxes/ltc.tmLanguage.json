{
	"name": "Lithic",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#types"
		},
		{
			"include": "#variables"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#reserved-words"
		},
		{
			"include": "#functions"
		},
		{
			"include": "#identifiers"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#numbers"
		}
	],
	"repository": {
		"keywords": {
			"patterns": [{
				"name": "keyword.control.flow",
				"match": "\\b(if|else|while|for|return|iterate|enumerate|goto|pass|import|as)\\b"
			},
			{
				"name": "storage.type.function",
				"match": "\\b(define|false|true)\\b",
				"comment":"Blue keywords are used for function definitions and boolean literals "
			}]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.block.ltc",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "support.type",
					"match": "\\b(f64|i8|u8|i16|u16|i32|u32|i64|u64|ptr|array|label|char|boolean|string|tuple)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator",
					"match": "\\+|\\-|\\*|\\/|%|==|!=|<=|>=|<|>|&|@|\\+\\+|\\-\\-|\\$|\\~|->|\\^|!|\\*\\*|\\/\\/|\\|\\||=|\\+=|\\-=|\\*=|\\/="
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric",
					"match": "\\b\\d+(\\.\\d+)?([eE][+-]?\\d+)?\\b"
				}
			]
		},
		"reserved-words": {
			"patterns": [
				{
					"name": "storage.modifier.declaration",
					"match": "\\b(let)\\b"
				},
				{
					"name": "support.function.builtin",
					"match": "\\b(print|printf|input|cmd|inline_C|inline_Asm|inline_IR|exit|length|typeof|sizeof|concat|aSet|malloc)\\b"
				}
			]
		},
		"variables": {
			"patterns": [
				{
					"comment": "Matches: let <type> <name> = ...",
					"match": "\\b(let)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
					"captures": {
						"1": { "name": "storage.modifier.declaration" },
						"2": { "name": "support.type" },
						"3": { "name": "variable.other.definition" }
					}
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"comment": "Generic identifier usage (exclude keywords, types, and builtins).",
					"name": "variable.other",
					"match": "\\b(?!if\\b|else\\b|while\\b|for\\b|return\\b|iterate\\b|enumerate\\b|goto\\b|pass\\b|define\\b|let\\b|print\\b|printf\\b|input\\b|cmd\\b|inline_C\\b|inline_Asm\\b|inline_IR\\b|exit\\b|sLength\\b|typeof\\b|sizeof\\b|sConcat\\b|aConcat\\b|aLength\\b|aSet\\b|f64\\b|i8\\b|u8\\b|i16\\b|u16\\b|i32\\b|u32\\b|i64\\b|u64\\b|ptr\\b|array\\b|label\\b|char\\b|boolean\\b|string\\b)([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*\\()"
				}
			]
		},

	"strings": {
		"patterns": [
			{
				"name": "string.quoted.double",
				"begin": "\"",
				"end": "\"",
				"patterns": [
					{
						"name": "constant.character.escape",
						"match": "\\\\."
					}
				]
			},
						{
				"name": "string.quoted.single",
				"begin": "'",
				"end": "'",
				"patterns": [
					{
						"name": "constant.character.escape",
						"match": "\\\\."
					}
				]
			}

		]
	},
	"functions": {
		"patterns": [
			{
			"comment": "Matches: define <name>(...)",
			"match": "\\b(define)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
			"captures": {
				"1": { "name": "storage.type.function" },
				"2": { "name": "entity.name.function" }
			}
			},
			{
			"name": "entity.name.function",
			"match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
			}
		]
		}
	},
	"scopeName": "source.ltc"
}
